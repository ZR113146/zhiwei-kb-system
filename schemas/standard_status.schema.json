{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Zhiwei KB Standard Status",
  "type": "object",
  "required": ["_meta", "standards"],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "generated_at": {"type": "string"},
        "source_manifest": {"type": "string"},
        "rule": {"type": "string"},
        "coverage": {"type": "object"}
      }
    },
    "standards": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["standard_code", "status"],
        "properties": {
          "standard_code": {"type": "string"},
          "display_code": {"type": "string"},
          "official_code": {"type": "string"},
          "standard_name": {"type": "string"},
          "year": {"type": ["integer", "null"]},
          "status": {"enum": ["effective", "superseded", "abolished", "draft", "unknown"]},
          "effective_date": {"type": "string"},
          "abolished_date": {"type": "string"},
          "replaced_by": {"type": "array", "items": {"type": "string"}},
          "standard_level": {"enum": ["national", "industry", "local", "association", "enterprise", "unknown"]},
          "jurisdiction": {"type": "string"},
          "confidence": {"type": "string"},
          "evidence_url": {"type": "string"},
          "evidence_urls": {"type": "string"},
          "evidence_source": {"type": "string"},
          "evidence_scope": {"type": "string"},
          "review_note": {"type": "string"},
          "source": {"type": "string"}
        }
      }
    }
  }
}
